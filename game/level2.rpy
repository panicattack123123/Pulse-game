# ============================================================
# PULSE — level2.rpy
# Уровень 2: «Бетонные стены покрыты мхом»
# Локация: Университет (Гардероб, Коридор, Столовая, Кабинет)
# ============================================================

label level2:

    # --------------------------------------------------------
    # ГАРДЕРОБ
    # --------------------------------------------------------
    scene bg_wardrobe with dissolve

    thought "Народу, как обычно, много."
    thought "Все стремятся быстрее сдать свою куртку и бежать в аудитории."
    pause 0.4
    thought "Блин, по-моему моя куртка выглядит странно."
    thought "Вон, у ребят какие дорогие, а моя какая-то стремная."
    pause 0.5
    thought "Ну почему же так долго?"

    scene black with dissolve
    pause 0.6

    # Нарратив — без озвучки, просто текст
    thought "Руслан сдал куртку и пошёл в свою аудиторию."
    pause 0.3
    thought "Он старался держаться ближе к стенам, чтобы его точно никто случайно не коснулся."
    pause 0.4
    thought "Руслан вообще не тактильный человек."
    pause 0.3
    thought "Всегда, когда нужно жать кому-то руку, он будто бы собирает все силы, чтобы это сделать."
    pause 0.3
    thought "А если нужно кого-то приобнять — это вообще катастрофа."

    # --------------------------------------------------------
    # КОРИДОР — встреча с Серёгой и Кириллом
    # --------------------------------------------------------
    scene bg_corridor with dissolve

    show sergey_normal at left
    show kirill_normal at right

    thought "Руслан продолжал идти на занятие, как вдруг его кто-то сзади похлопал по плечу."

    pause 0.5

    sergey "Видок, конечно, у тебя как всегда так себе."
    pause 0.2
    sergey "Попробуй подать заявку в актёры на фильм «Пули Справедливости»."
    sergey "Может тебя и примут на роль зомбака, ха-ха…"

    kirill "Ты опять плохо спал или что?"

    thought "Руслан понимал, что его друзья шутят, и в их словах нет ничего с целью обидеть."
    thought "Хороший юмор он любил, но сам хорошо шутить не умел."

    show sergey_weird at left
    show kirill_weird at right

    ruslan "Да вот думал, кстати, пойти в актёры."
    ruslan "Я был бы самым страшным зомби."

    pause 0.5
    sergey "Мда…"
    pause 0.2
    sergey "Ладно, пойдемте уже."
    sergey "Не хочу опоздать на пару, потом ещё не запустят."

    hide sergey_weird
    hide kirill_weird

    scene black with dissolve
    pause 0.6
    play sound "audio/crowd.ogg"
    pause 0.6

    # --------------------------------------------------------
    # АУДИТОРИЯ — доска
    # --------------------------------------------------------
    scene bg_classroom_board with dissolve

    thought "Пара началась."
    thought "Преподаватель увлечённо пишет на доске какие-то определения по генетике."
    thought "Кто-то на задних партах шепчется, тихо хихикает."

    # --------------------------------------------------------
    # АУДИТОРИЯ — парта, мини-игра конспект
    # --------------------------------------------------------
    scene bg_classroom_desk with dissolve

    thought "Руслан открыл свою тетрадь и взял ручку."
    thought "Пора писать конспект."
    thought "В этом деле главное — успевать за мыслями преподавателя и умело переносить их на бумагу."

    # --- МИНИ-ИГРА: Конспект-лабиринт ---
    call minigame_note_run from _call_minigame_note_run

    # --------------------------------------------------------
    # АУДИТОРИЯ — конец пары
    # --------------------------------------------------------
    scene bg_classroom_board with dissolve

    teacher "…и по этому определению мы понимаем, какие особенности передаются ребёнку от его родителей."
    pause 0.3
    teacher "На этом наша встреча окончена."
    teacher "Если у кого-то остались вопросы — подойдите ко мне сейчас."
    teacher "Если всё хорошо — можете идти."

    scene black with dissolve
    pause 0.4

    thought "Студенты повскакивали со своих мест и отправились к выходу."
    thought "Руслан тоже встал и собрал вещи."
    thought "Его ждали Кирилл и Серёга."

    # Переход к столовой — задел на следующие сцены
    jump level2_canteen


label level2_canteen:
    scene bg_canteen with dissolve

    show sergey_normal at left
    show kirill_normal at right

    # Здесь продолжится сюжет столовой
    # — заглушка, пока сценарий пишется дальше
    thought "— (Сцена столовой — в разработке) —"

jump endgame_credits
