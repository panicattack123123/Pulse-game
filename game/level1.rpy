# ============================================================
# PULSE — level1.rpy
# Уровень 1: «Почему моё утро не доброе?»
# Локация: Квартира (Спальня / Ванная)
# ============================================================

label level1:

    # --------------------------------------------------------
    # СПАЛЬНЯ — пробуждение
    # --------------------------------------------------------
    scene black with dissolve
    pause 1.2

    thought "Я уже две недели не слышу ничего, кроме гула холодильника и собственного дыхания."
    pause 0.4
    thought "Переезд должен был стать «новым этапом», но стал просто сменой декораций для моего потолка."
    pause 0.4

    scene bg_bedroom with dissolve   # спальня, тёмная

    thought "Нужно…"
    pause 0.3
    thought "Встать…"

    # --- МИНИ-ИГРА: Подъём ---
    call minigame_alarm_run from _call_minigame_alarm_run

    # После мини-игры
    thought "Возможно, сегодня я себя чувствую лучше, чем вчера."
    pause 0.3
    thought "Или нет.."

    # --------------------------------------------------------
    # ВАННАЯ — зеркало
    # --------------------------------------------------------
    scene ruslan_mirror with dissolve

    ruslan "Игорь бы сейчас уже был в зале."
    pause 0.2
    ruslan "Мать бы…"
    pause 0.2
    ruslan "Чёрт знает, где бы она была."
    pause 0.2
    ruslan "А я здесь."

    pause 0.6

    ruslan "Как же я уродлив…"
    ruslan "Ненавижу свою морду…"
    pause 0.5
    ruslan "Я сильно оброс."
    ruslan "Нужно побриться, гляди — стану более красивым."

    # --- МИНИ-ИГРА: Честное Бритьё без зон ---
    call minigame_shave_run from _call_minigame_shave_run

    # После бритья
    ruslan "Ладно. Достаточно."

    pause 0.5

    thought "Ну…"
    thought "Вроде что-то да изменилось…"
    pause 0.3
    thought "Хотя нет."
    thought "Стало хуже."
    thought "Теперь мои некрасивые скулы стали видны."
    thought "Ещё и глаза глупые такие."
    thought "Почему вот брату досталась хорошая генетика, а я как уродец?"

    # --------------------------------------------------------
    # СПАЛЬНЯ — сборы
    # --------------------------------------------------------
    scene bg_bedroom with dissolve
    show ruslan_room at center         # Руслан у стола

    thought "Пора идти на пары."
    thought "Ненавижу пары."
    thought "Какой смысл мне на них ходить, если я и так ничего не запоминаю."
    pause 0.3
    thought "Надо было всё-таки поступать на математика, а не на биолога,"
    thought "но тогда бы я жил дома."
    pause 0.3
    thought "Дома — вечные упрёки, вынос мозга и ужасная атмосфера."
    thought "Я поступал сюда просто, чтобы маму с братом не видеть,"
    thought "чтобы уехать оттуда."

    # --------------------------------------------------------
    # ПОДЪЕЗД
    # --------------------------------------------------------
    scene bg_hallway with dissolve

    thought "Пропуск — взял."
    thought "Тетрадку — взял."
    thought "Дверь — закрыл."
    thought "Всё, можно идти."

    # --------------------------------------------------------
    # УЛИЦА 1
    # --------------------------------------------------------
    scene bg_street1 with dissolve

    thought "Сегодня тепло."
    thought "Даже очень."

    menu:
        "Достать наушники?":
            jump headphones_yes
        "Нет":
            jump headphones_no

label headphones_yes:
    thought "Чёрт…"
    thought "Наушники сели."
    thought "Почему я их вчера не поставил на зарядку,"
    thought "я же знал, что они сядут."
    thought "Почему я забил на это?"
    pause 0.6
    # Тоска
    scene bg_street1 with dissolve
    $ renpy.pause(0.3)
    thought "Внезапно на Руслана накатила какая-то необъяснимая тоска."
    thought "Будто он потерял окончательно всё то, что любил… пусть и на время."
    jump street2

label headphones_no:
    jump street2

label street2:

    # --------------------------------------------------------
    # УЛИЦА 2 — тревога о двери
    # --------------------------------------------------------
    scene bg_street2 with dissolve

    thought "Почти пришёл."
    thought "Интересно, придут ли Серёга с Кириллом…"
    pause 0.5

    thought "А закрыл ли я дверь?"
    pause 0.3
    thought "Закрыл же, я долго мешкался у неё."
    thought "Я даже сказал себе, что закрыл."
    thought "Я закрыл её, правда…"

    scene black with dissolve
    pause 0.8

    thought "Так, сейчас нужно пройти турникет."
    thought "У меня в рюкзаке пропуск."
    thought "Он сейчас там окажется, я достану его и приложу к датчику."
    pause 0.3
    thought "А если турникет не распознает мою карточку?"
    pause 0.2
    thought "Нет,"
    thought "распознает!"
    thought "Всегда распознавал!"
    thought "И сегодня распознает!"

    scene black with dissolve
    pause 0.5
    play sound "audio/beep.ogg"
    pause 0.3
    play sound "audio/steps_exhale.ogg"
    pause 0.6

    jump level2


# ============================================================
# ТОЧКА ВХОДА ДЛЯ БРИТЬЯ
# ============================================================
label minigame_shave_run:
    call screen minigame_shave
    scene ruslan_shaved with dissolve
    return